extern void printf(char* fmt, ...);
extern void* malloc(int size);
extern void free(void* ptr);

int main() {
    int* arr;
    int size = 5;
    
    arr = malloc(size * 4);
    
    // Initialize manually
    *(arr + 0) = 1;
    *(arr + 1) = 2;
    *(arr + 2) = 3;
    *(arr + 3) = 4;
    *(arr + 4) = 5;
    
    printf("arr[2] = %d\n", *(arr + 2));
    
    free(arr);
    return 0;
}